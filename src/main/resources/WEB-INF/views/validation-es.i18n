# validation-es.i18n

acme.validation.header.message                = El texto debe tener entre 1 y 75 caracteres y no puede estar en blanco
acme.validation.text.message                  = El texto debe tener entre 1 y 255 caracteres y no puede estar en blanco
acme.validation.ticker.message                = El ticker debe tener 2 letras mayúsculas, 2 números, un guion y entre 5 y 10 caracteres
acme.validation.duplicated-ticker.message     = Referencia ya usada
acme.validation.correctDates.message          = El momento de inicio debe de ser antes del momento de finalización.
acme.validation.numberOfTactics.message       = Las estrategias no se pueden publicar si no tienen al menos una táctica asociada
acme.validation.numberOfMilestones.message    = Las campañas no se pueden publicar si no tienen al menos un hito asociado
acme.validation.numberOfAuditSections.message = Los informes de auditoría no se pueden publicar si no tienen al menos una sección de auditoría
acme.validation.numberOfParts.message         = Las invenciones no se pueden publicar si no tienen al menos una parte
acme.validation.numberOfDonations.message     = Los patrocinios no se pueden publicar si no tienen al menos una donación
acme.validation.currency.message              = La moneda debe ser en euros
acme.validation.future-interval.message 	= Las fechas deben estar en futuro

